rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isOfficial() {
      return hasRole('official');
    }

    function isResponder() {
      return hasRole('responder');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. User Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
               data.uid is string && data.email is string && data.role in ['citizen', 'official', 'responder'] &&
               data.displayName is string && data.displayName.size() <= 100;
      }

      allow get: if isSignedIn() && (isOwner(userId) || isOfficial());
      allow list: if isOfficial(); // Only officials can list all users
      
      allow create: if isSignedIn() && isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().role == 'citizen' && // Force new users to be citizens
                      incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && isOwner(userId) && (
        // Action: Update Profile
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'lastLocation']) &&
         incoming().displayName is string && incoming().displayName.size() <= 100)
      );
    }

    // 2. Report Rules
    match /reports/{reportId} {
      function isValidReport(data) {
        return data.keys().hasAll(['reporterId', 'type', 'description', 'location', 'status', 'createdAt']) &&
               data.reporterId == request.auth.uid &&
               data.type in ['accident', 'crime', 'flooding', 'fire', 'medical'] &&
               data.description is string && data.description.size() <= 5000 &&
               data.status in ['pending', 'verified', 'responding', 'resolved'] &&
               data.location.lat is number && data.location.lng is number &&
               (data.get('reporterName', '') is string);
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() && 
                      isValidReport(incoming()) && 
                      incoming().status == 'pending' &&
                      incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && (
        // Action: Citizen Update (only before resolution)
        (isOwner(existing().reporterId) && 
         existing().status == 'pending' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['description', 'mediaUrls', 'location', 'updatedAt']) &&
         incoming().updatedAt == request.time) ||
        
        // Action: Official/Responder Status change
        ((isOfficial() || isResponder()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         incoming().updatedAt == request.time)
      );
      
      allow delete: if isOfficial();
    }

    // 3. Alert Rules
    match /alerts/{alertId} {
      function isValidAlert(data) {
        return data.keys().hasAll(['title', 'message', 'category', 'severity', 'createdAt']) &&
               data.title is string && data.title.size() <= 200 &&
               data.message is string && data.message.size() <= 2000 &&
               data.category in ['weather', 'security', 'traffic', 'health'] &&
               data.severity in ['low', 'medium', 'critical'];
      }

      allow read: if isSignedIn();
      allow write: if isOfficial() && isValidAlert(incoming()) && (
        (request.method == 'create' && incoming().createdAt == request.time) ||
        (request.method == 'update' && incoming().updatedAt == request.time)
      );
    }

    // 4. Message Rules (Subcollection of reports)
    match /reports/{reportId}/messages/{messageId} {
      function isValidMessage(data) {
        return data.keys().hasAll(['senderId', 'senderName', 'text', 'createdAt']) &&
               data.senderId == request.auth.uid &&
               data.senderName is string && data.senderName.size() <= 100 &&
               data.text is string && data.text.size() <= 1000;
      }

      function isReportParticipant() {
        let report = get(/databases/$(database)/documents/reports/$(reportId)).data;
        return report.reporterId == request.auth.uid || isOfficial() || isResponder();
      }

      allow read: if isSignedIn() && isReportParticipant();
      allow create: if isSignedIn() && isReportParticipant() && 
                      isValidMessage(incoming()) && 
                      incoming().createdAt == request.time;
    }
  }
}
